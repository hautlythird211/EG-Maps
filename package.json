{
  "name": "centralized-maps",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "nuxt prepare && node scripts/patch-eslint-flat-config.mjs",
    "tiles:download": "node scripts/download-tiles.mjs",
    "tiles:stats": "node -e \"const {readdirSync, statSync, existsSync} = require('fs'); const {resolve} = require('path'); const d='public/tiles'; if(!existsSync(d)){console.log('No tiles directory');process.exit(0)} let total=0,bytes=0; for(const z of readdirSync(d)){for(const x of readdirSync(resolve(d,z))){for(const f of readdirSync(resolve(d,z,x))){total++;bytes+=statSync(resolve(d,z,x,f)).size}}}; console.log('Tiles:',total.toLocaleString());console.log('Size:',(bytes/1024/1024).toFixed(1),'MB');\""
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/gesture": "^2.0.0",
    "@vueuse/motion": "^3.0.3",
    "clsx": "^2.1.1",
    "iconify-icon": "^3.0.2",
    "maplibre-gl": "^5.24.0",
    "nuxt": "^3.21.6",
    "pinia": "^3.0.4",
    "playwright": "^1.60.0",
    "reka-ui": "^2.9.9",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.60.0",
    "@types/geojson": "^7946.0.16",
    "@types/supercluster": "^7.1.3",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
